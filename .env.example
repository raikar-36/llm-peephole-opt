# LLM Peephole Optimization — Environment Variables
# Copy to .env and fill in: cp .env.example .env
# Then source it: source .env

# ── LLM Provider ──────────────────────────────────────────────
# Options: "gemini" or "groq"
export LLM_PROVIDER="groq"

# ── Gemini API Keys (comma-separated, 3-key rotation) ────────
export GEMINI_API_KEYS="key1,key2,key3"

# ── Groq API Key (Optional) ───────────────────────────────────
export GROQ_API_KEY="your_groq_api_key_here"

# ── Model Names ───────────────────────────────────────────────
export GEMINI_MODEL="gemini-3.1-flash-lite"
export GROQ_MODEL="openai/gpt-oss-120b"

# ── Alive2 Path (for Tier 3 formal verification) ─────────────
export ALIVE2_PATH="$HOME/alive2/build/alive"
